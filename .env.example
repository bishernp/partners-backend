SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# PostgreSQL connection (libpq URL). Examples:
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
#   postgres://USER@localhost:5432/bnp_partners   (local trust auth)
DATABASE_URL=postgres://USER@localhost:5432/bnp_partners
# Comma-separated origins allowed to call the API (frontend + dashboard).
CORS_ALLOWED_ORIGINS=http://localhost:5176,http://localhost:5177
# The single public origin permitted to submit onboarding forms.
FRONTEND_ORIGIN=http://localhost:5176
